# URL du serveur Magasin TGE (avec https si Cloudflare Tunnel)
SERVER_URL=https://magasin.example.com

# Token d'authentification (doit correspondre au PRINT_TOKEN du serveur)
PRINT_TOKEN=changez-moi

# USB Vendor ID et Product ID de l'imprimante (lsusb pour trouver)
# Exemple pour une imprimante générique 80mm:
PRINTER_VID=0x0416
PRINTER_PID=0x5011
